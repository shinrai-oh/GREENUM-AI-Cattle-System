# 数据库连接 (MySQL)
DATABASE_URL="mysql://cattle_user:cattle_pass@localhost:3306/cattle_unified?charset=utf8mb4"

# JWT 密钥 (生产环境请替换为随机长字符串)
JWT_SECRET="change-me-in-production-use-random-string"

# 服务端口
PORT=3000

# Python Sidecar 地址 (RTSP/OpenCV)
PYTHON_SIDECAR_URL="http://python-sidecar:5000"

# 环境
NODE_ENV="production"

# 初始管理员 (首次启动时自动创建)
INIT_ADMIN_USERNAME="admin"
INIT_ADMIN_PASSWORD="admin123"
